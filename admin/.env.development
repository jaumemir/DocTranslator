# Development environment custom environment variables (must start with VITE_)

## Backend API public path (if using reverse proxy for CORS, only public path is needed)
VITE_BASE_API = 'http://localhost:5000'

## Router mode: hash or html5
VITE_ROUTER_HISTORY = 'history'

## Development environment path prefix (usually '/' or './' works)
VITE_PUBLIC_PATH = '/'
